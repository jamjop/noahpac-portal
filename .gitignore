# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# Python bytecode cache — each app's check_updates.py generates its own
# __pycache__/ on every cron run; never source, shouldn't be committed
__pycache__/
*.pyc

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------
# Replit-only — files below stay on disk for the dev environment
# but are not part of the deployed nginx static content.
# -----------------------------------------------------------------------

# Replit platform config (env-specific, not committed)
.replitignore
.npmrc

# Replit dev environment state
.cache/

# Replit Express wrapper (serves workspace root in dev; not needed in git)
artifacts/
# Track the noahpac React app source so CSS token fallbacks are versioned
!artifacts/noahpac/
!artifacts/noahpac/src/
!artifacts/noahpac/src/index.css

# Replit file attachments
attached_assets/

# Cursor/GitHub Copilot AI rules (Replit-generated, not nginx content)
.cursor/
.github/*
!.github/workflows/
.github/workflows/*
!.github/workflows/*.yml

# Live data files — written by cron jobs, not source
screener/data/
# antibiogram/data/ — tracked: empiric page fetches these as runtime static assets
# antibiogram/data/pending/ — held-for-review extractions flagged by validate_facility()
# in auto_update.py; not live data, stays local until manually reviewed and promoted
antibiogram/data/pending/
**/known_pmids.json
**/known_state.json
**/known_files.json
**/last_checked.json


# Playwright ephemeral output — generated per run, not source
test-results/
