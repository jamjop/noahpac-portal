# System Files
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------
# Replit-only — everything below stays on disk for the dev environment
# but is NOT needed for nginx hosting and must not be in the git repo.
# -----------------------------------------------------------------------

# Replit platform config
.replit
.replitignore
.npmrc

# Replit dev environment
.agents/
.cache/
.local/
replit.md

# Replit workspace infrastructure (pnpm monorepo, TypeScript config)
artifacts/
lib/
scripts/
package.json
tsconfig.base.json
tsconfig.json
pnpm-workspace.yaml
pnpm-lock.yaml

# Replit dev server
server.js

# Replit file attachments
attached_assets/

# Cursor/GitHub Copilot AI rules (Replit-generated, not nginx content)
.cursor/
.github/

# Live data files — written by cron jobs, not source
screener/data/
antibiogram/data/
**/known_pmids.json
**/known_state.json
**/known_files.json
